{
  "schemaVersion": "1",
  "rules": [
    {
      "id": "no-print",
      "severity": "medium",
      "match": {
        "kind": "structural",
        "pattern": "print($MSG)"
      },
      "scope": {
        "paths": [
          "*.py"
        ],
        "languages": [
          "Python"
        ]
      },
      "message": "Avoid print(); use the logging module instead."
    },
    {
      "id": "demo-no-eval",
      "severity": "medium",
      "match": {
        "kind": "structural",
        "pattern": "eval($X)"
      },
      "scope": {
        "paths": [
          "*.py"
        ],
        "languages": [
          "Python"
        ]
      },
      "message": "Avoid eval()."
    },
    {
      "id": "require-docstrings",
      "severity": "medium",
      "match": {
        "kind": "nl",
        "instruction": "Every Python function must have a docstring describing what it does."
      },
      "scope": {
        "paths": [
          "*.py"
        ]
      },
      "message": "Every Python function should have a docstring."
    }
  ]
}
